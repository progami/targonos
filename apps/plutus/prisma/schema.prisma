generator client {
  provider = "prisma-client-js"
  output   = "../../../packages/prisma-plutus/generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// SetupConfig stores the QBO account mappings and setup state
/// There should only be one row in this table per tenant
model SetupConfig {
  id        String   @id @default(cuid())
  
  // Amazon settlement parent accounts used to collapse legacy brand-level sales/refund postings.
  amazonSales                      String?
  amazonRefunds                    String?
  amazonFbaInventoryReimbursement  String?
  amazonSellerFees                 String?
  amazonFbaFees                    String?
  amazonStorageFees                String?
  amazonAdvertisingCosts           String?
  amazonPromotions                 String?

  // Setup status
  accountsCreated Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// SettlementPostingConfig stores memo→account mappings needed to post settlement JEs.
/// Used for deterministic mapping when ingesting settlements directly (e.g., US SP-API Finances).
model SettlementPostingConfig {
  id String @id @default(cuid())

  /// Marketplace identifier (e.g. "amazon.com")
  marketplace String @unique

  /// QBO account id for the payout line when OriginalTotal is positive ("Transfer to Bank")
  bankAccountId String?

  /// QBO account id for the payout line when OriginalTotal is negative ("Payment to Amazon")
  paymentAccountId String?

  /// Maps settlement memo strings to QBO account ids.
  accountIdByMemo Json @db.JsonB

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([marketplace])
}

/// AuditDataUpload tracks a single transaction/audit data import.
/// One import may contain rows for multiple settlements (invoice groups).
model AuditDataUpload {
  id        String   @id @default(cuid())
  filename  String
  rowCount  Int
  invoiceCount Int
  uploadedAt DateTime @default(now())

  rows AuditDataRow[]
}

/// AuditDataRow stores a single transaction row used for settlement processing.
/// Rows are grouped by invoiceId which maps to one settlement doc number (e.g. US-... or UK-...).
model AuditDataRow {
  id        String   @id @default(cuid())

  invoiceId   String
  market      String
  date        String   // YYYY-MM-DD
  orderId     String
  sku         String
  quantity    Int
  description String
  net         Int      // cents

  uploadId String
  upload   AuditDataUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([uploadId])
  @@index([uploadId, invoiceId])
}

/// SettlementProcessing tracks Plutus processing for a single settlement invoice group.
/// Used for idempotency, history, and settlement list status.
model SettlementProcessing {
  id String @id @default(cuid())

  marketplace              String // e.g., "amazon.com", "amazon.co.uk"
  qboSettlementJournalEntryId String
  settlementDocNumber      String   @map("lmbDocNumber")
  settlementPostedDate     DateTime @map("lmbPostedDate")

  invoiceId       String
  processingHash  String
  sourceFilename  String
  uploadedAt      DateTime @default(now())

  qboCogsJournalEntryId      String
  qboPnlReclassJournalEntryId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([marketplace, invoiceId])
  @@unique([qboSettlementJournalEntryId])
  @@index([marketplace])
  @@index([marketplace, createdAt])
}

/// SettlementRollback tracks manual rollbacks of processed settlements.
/// We keep these rows even though the SettlementProcessing row is deleted so the UI can show
/// "rolled back" status and keep a simple audit trail.
model SettlementRollback {
  id String @id @default(cuid())

  marketplace                String
  qboSettlementJournalEntryId String
  settlementDocNumber        String   @map("lmbDocNumber")
  settlementPostedDate       DateTime @map("lmbPostedDate")

  invoiceId      String
  processingHash String
  sourceFilename String
  processedAt    DateTime

  qboCogsJournalEntryId       String
  qboPnlReclassJournalEntryId String

  orderSalesCount   Int
  orderReturnsCount Int

  rolledBackAt DateTime @default(now())

  @@index([qboSettlementJournalEntryId])
  @@index([marketplace])
}

/// AuditLog tracks user actions across the Plutus app for audit trail purposes.
model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  userName   String
  action     String   // e.g., "SETTLEMENT_PROCESSED", "SETTLEMENT_ROLLED_BACK", "CONFIG_UPDATED", "ACCOUNTS_CREATED"
  entityType String   // e.g., "SettlementProcessing", "SetupConfig", "QboAccount"
  entityId   String?
  details    Json?    // Additional context
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model PostingIntent {
  id             String   @id @default(cuid())
  sourceType     String
  sourceId       String
  market         String
  periodStart    String?
  periodEnd      String?
  sourceHash     String
  mappingVersion String
  postingHash    String
  status         String   @default("draft")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lines       PostingIntentLine[]
  qboPostings QboPosting[]

  @@unique([sourceType, sourceId])
  @@index([market])
  @@index([status])
}

model PostingIntentLine {
  id              String   @id @default(cuid())
  postingIntentId String
  lineRef         String
  category        String
  accountId       String?
  amountCents     Int
  currency        String
  description     String
  lineHash        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  postingIntent PostingIntent @relation(fields: [postingIntentId], references: [id], onDelete: Cascade)

  @@unique([postingIntentId, lineRef])
  @@index([postingIntentId])
}

model QboPosting {
  id               String    @id @default(cuid())
  postingIntentId  String
  qboTxnType       String
  qboTxnId         String
  qboSyncToken     String?
  qboDocNumber     String?
  qboPrivateNote   String?
  qboTxnDate       String?
  postingHash      String
  driftStatus      String    @default("unchecked")
  attachmentStatus String    @default("missing")
  lastCheckedAt    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  postingIntent    PostingIntent              @relation(fields: [postingIntentId], references: [id], onDelete: Cascade)
  lineFingerprints QboPostingLineFingerprint[]

  @@unique([qboTxnType, qboTxnId])
  @@index([postingIntentId])
  @@index([driftStatus])
}

model QboPostingLineFingerprint {
  id               String   @id @default(cuid())
  qboPostingId     String
  qboLineId        String
  expectedLineHash String
  liveLineHash     String?
  driftStatus      String   @default("unchecked")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  qboPosting QboPosting @relation(fields: [qboPostingId], references: [id], onDelete: Cascade)

  @@unique([qboPostingId, qboLineId])
  @@index([qboPostingId])
  @@index([driftStatus])
}

/// ProductGroup is the small operator-facing grouping layer above sellable products.
/// It is not a QBO chart-of-accounts dimension and is not used for posting brand P&L.
model ProductGroup {
  id     String  @id @default(cuid())
  code   String  @unique
  name   String
  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products CanonicalProduct[]

  @@index([active])
}

/// CanonicalProduct is the Plutus product identity used to connect US/UK/Amazon aliases.
model CanonicalProduct {
  id             String @id @default(cuid())
  productGroupId String
  code           String
  name           String
  active         Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productGroup       ProductGroup          @relation(fields: [productGroupId], references: [id], onDelete: Restrict)
  skuAliases         SkuAlias[]
  poCostLayers       PoCostLayer[]
  inventoryMovements InventoryMovement[]
  consumptions       CostLayerConsumption[]
  sellerboardExports SellerboardCogsExport[]

  @@unique([code])
  @@index([productGroupId])
  @@index([active])
}

/// SkuAlias maps marketplace seller SKUs and alternate SKU forms to one canonical product.
model SkuAlias {
  id                 String  @id @default(cuid())
  canonicalProductId String
  marketplace        String
  aliasType          String
  value              String
  normalizedSellerSku String
  active             Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  canonicalProduct CanonicalProduct @relation(fields: [canonicalProductId], references: [id], onDelete: Cascade)

  @@unique([marketplace, normalizedSellerSku])
  @@unique([marketplace, aliasType, value])
  @@index([canonicalProductId])
  @@index([marketplace])
  @@index([active])
}

/// PurchaseOrder mirrors QBO purchase-order identity; QBO remains the source document system.
model PurchaseOrder {
  id          String  @id @default(cuid())
  internalRef String
  sourceType  String
  sourceId    String
  supplierRef String?
  marketplace String?
  status      String  @default("OPEN")
  sourceNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourceDocuments SourceDocument[]
  landedBatches   LandedCostBatch[]
  poCostLayers    PoCostLayer[]

  @@unique([sourceType, sourceId])
  @@index([internalRef])
  @@index([marketplace])
  @@index([status])
}

/// SourceDocument stores the QBO bill/PO/vendor-credit line evidence that feeds a landed batch.
model SourceDocument {
  id                String  @id @default(cuid())
  purchaseOrderId   String?
  landedCostBatchId String?
  qboTxnType        String
  qboTxnId          String
  qboLineId         String?
  qboPurchaseOrderId     String?
  qboPurchaseOrderLineId String?
  docNumber         String?
  vendorName        String?
  txnDate           String?
  amountCents       Int
  currency          String
  attachmentStatus  String  @default("missing")
  sourceHash        String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrder   PurchaseOrder?   @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  landedCostBatch LandedCostBatch? @relation(fields: [landedCostBatchId], references: [id], onDelete: SetNull)

  @@unique([qboTxnType, qboTxnId, qboLineId])
  @@index([purchaseOrderId])
  @@index([landedCostBatchId])
  @@index([qboTxnType, qboTxnId])
  @@index([qboPurchaseOrderId])
  @@index([qboPurchaseOrderLineId])
  @@index([attachmentStatus])
}

/// QboLandedCostAllocation links non-PO landed-cost bill lines to QBO PO/SKU layers.
model QboLandedCostAllocation {
  id                         String @id @default(cuid())
  qboBillId                  String
  qboBillLineId              String
  qboPurchaseOrderId         String
  qboPurchaseOrderLineId     String
  qboPurchaseOrderDocNumber  String
  sellerSku                  String
  component                  String
  amountCents                Int
  quantity                   Int?
  allocationMethod           String
  sourceRef                  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([qboBillId, qboBillLineId, qboPurchaseOrderId, qboPurchaseOrderLineId, sellerSku, component])
  @@index([qboPurchaseOrderId])
  @@index([qboPurchaseOrderLineId])
  @@index([sellerSku])
  @@index([component])
}

/// LandedCostBatch groups QBO purchase, freight, duty, and packaging evidence into one costing batch.
model LandedCostBatch {
  id              String    @id @default(cuid())
  purchaseOrderId String
  batchRef        String
  marketplace     String
  currency        String
  status          String    @default("draft")
  lockedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrder   PurchaseOrder    @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  sourceDocuments SourceDocument[]
  poCostLayers    PoCostLayer[]

  @@unique([purchaseOrderId, batchRef])
  @@index([marketplace])
  @@index([status])
  @@index([lockedAt])
}

/// PoCostLayer is the exact PO/SKU landed-cost layer that Plutus consumes for COGS.
model PoCostLayer {
  id                 String    @id @default(cuid())
  purchaseOrderId    String
  landedCostBatchId  String?
  canonicalProductId String
  marketplace        String
  sellerSku          String
  component          String
  quantity           Int
  amountCents        Int
  currency           String
  allocationMethod   String
  receiptDate        DateTime?
  sourceQboTxnType   String?
  sourceQboTxnId     String?
  sourceQboLineId    String?
  sourceDocumentName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrder    PurchaseOrder          @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  landedCostBatch  LandedCostBatch?       @relation(fields: [landedCostBatchId], references: [id], onDelete: SetNull)
  canonicalProduct CanonicalProduct       @relation(fields: [canonicalProductId], references: [id], onDelete: Restrict)
  consumptions     CostLayerConsumption[]

  @@unique([purchaseOrderId, canonicalProductId, component])
  @@index([marketplace])
  @@index([sellerSku])
  @@index([canonicalProductId])
  @@index([component])
  @@index([sourceQboTxnType, sourceQboTxnId])
}

/// InventoryMovement stores Amazon-derived unit movement evidence before FIFO COGS consumption.
model InventoryMovement {
  id                 String   @id @default(cuid())
  canonicalProductId String
  marketplace        String
  sellerSku          String
  movementType       String
  quantity           Int
  movementDate       DateTime
  settlementDocNumber String?
  sourceType         String
  sourceId           String
  sourceLineId       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  canonicalProduct CanonicalProduct @relation(fields: [canonicalProductId], references: [id], onDelete: Restrict)

  @@unique([sourceType, sourceId, sourceLineId])
  @@index([canonicalProductId])
  @@index([marketplace])
  @@index([sellerSku])
  @@index([movementType])
  @@index([movementDate])
  @@index([settlementDocNumber])
}

/// CogsPostingBatch is one exact COGS posting batch per settlement.
model CogsPostingBatch {
  id                  String  @id @default(cuid())
  marketplace         String
  settlementDocNumber String
  txnDate             String
  currency            String
  status              String  @default("draft")
  qboJournalEntryId   String?
  qboDocNumber        String?
  sourceHash          String
  postingHash         String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  consumptions       CostLayerConsumption[]
  sellerboardExports SellerboardCogsExport[]

  @@unique([marketplace, settlementDocNumber])
  @@index([settlementDocNumber])
  @@index([status])
  @@index([qboJournalEntryId])
}

/// CostLayerConsumption records the FIFO PO/SKU layer consumption behind each COGS posting.
model CostLayerConsumption {
  id                  String @id @default(cuid())
  cogsPostingBatchId  String
  poCostLayerId       String?
  canonicalProductId  String
  marketplace         String
  settlementDocNumber String
  internalPo          String
  sellerSku           String
  quantity            Int
  amountCents         Int
  currency            String
  componentAmounts    Json   @db.JsonB
  sourceHash          String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cogsPostingBatch CogsPostingBatch @relation(fields: [cogsPostingBatchId], references: [id], onDelete: Cascade)
  poCostLayer      PoCostLayer?     @relation(fields: [poCostLayerId], references: [id], onDelete: SetNull)
  canonicalProduct CanonicalProduct @relation(fields: [canonicalProductId], references: [id], onDelete: Restrict)

  @@unique([cogsPostingBatchId, internalPo, sellerSku])
  @@index([poCostLayerId])
  @@index([canonicalProductId])
  @@index([marketplace])
  @@index([settlementDocNumber])
  @@index([internalPo])
  @@index([sellerSku])
}

/// SellerboardCogsExport records the exact COGS rows exported for Sellerboard.
model SellerboardCogsExport {
  id                  String    @id @default(cuid())
  cogsPostingBatchId  String
  canonicalProductId  String
  marketplace         String
  settlementDocNumber String
  sellerSku           String
  internalPo          String
  quantity            Int
  amountCents         Int
  currency            String
  status              String    @default("draft")
  exportedAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cogsPostingBatch CogsPostingBatch @relation(fields: [cogsPostingBatchId], references: [id], onDelete: Cascade)
  canonicalProduct CanonicalProduct @relation(fields: [canonicalProductId], references: [id], onDelete: Restrict)

  @@unique([cogsPostingBatchId, sellerSku, internalPo])
  @@index([marketplace])
  @@index([settlementDocNumber])
  @@index([status])
  @@index([exportedAt])
}

/// PlutusException blocks posting when exact source evidence is missing or ambiguous.
model PlutusException {
  id          String    @id @default(cuid())
  marketplace String?
  scopeType   String
  scopeId     String
  code        String
  severity    String    @default("blocking")
  message     String
  status      String    @default("open")
  details     Json?     @db.JsonB
  resolvedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([marketplace])
  @@index([scopeType, scopeId])
  @@index([code])
  @@index([status])
  @@index([severity])
}

/// AwdDataUpload tracks AWD monthly fee report uploads used for deterministic AWD fee allocation.
model AwdDataUpload {
  id         String   @id @default(cuid())

  reportType  String // e.g., "AWD_FEE_MONTHLY"
  marketplace String // e.g., "amazon.com", "amazon.co.uk"
  filename    String

  startDate String // YYYY-MM-DD (min month start from parsed rows)
  endDate   String // YYYY-MM-DD (max month end from parsed rows)

  rowCount Int
  skuCount Int
  minDate  String // YYYY-MM-DD
  maxDate  String // YYYY-MM-DD

  uploadedAt DateTime @default(now())

  rows AwdDataRow[]

  @@index([marketplace])
  @@index([reportType])
  @@index([marketplace, reportType])
  @@index([uploadedAt])
  @@index([marketplace, startDate, endDate])
}

/// AwdDataRow stores SKU-level monthly fee amounts from an AWD fee report.
model AwdDataRow {
  id String @id @default(cuid())

  uploadId        String
  monthStartDate  String // YYYY-MM-DD
  monthEndDate    String // YYYY-MM-DD
  sku             String
  feeType         String
  /// Optional charge type for fee rows that distinguish inbound vs outbound charges (e.g., processing fees).
  chargeType      String?
  feeCents        Int
  currency        String

  upload AwdDataUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([uploadId])
  @@index([uploadId, monthStartDate, monthEndDate])
  @@index([uploadId, feeType, chargeType])
  @@index([sku])
}
